# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment variables — never commit these.
# NOTE: Vite inlines any VITE_* var into the client bundle, so it is public.
# Real secrets belong in a serverless function, not here.
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vercel (.env.local holds an OIDC token — already covered by .env.* above)
.vercel
